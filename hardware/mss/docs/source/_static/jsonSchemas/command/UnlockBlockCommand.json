{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://github.com/Epic-Breakfast-Productions/OpenQuarterMaster/blob/main/hardware/mss/jsonSchemas/GetModuleInfoCommand.json",
	"title": "Get Info Command",
	"description": "Command to get a module's info.",
	"type": "object",
	"allOf": [
		{
			"$ref": "https://github.com/Epic-Breakfast-Productions/OpenQuarterMaster/blob/main/hardware/mss/jsonSchemas/Command.json"
		}
	],
	"properties": {
		"command": {
			"description": "The command.",
			"type": "string",
			"const": "UNLOCK_BLOCK"
		},
		"duration": {
			"description": "The duration to unlock the block(s) for. Default to indefinitely.",
			"type": "string",
			"default": "indefinitely"
		},
		"all": {
			"description": "If we are to lock all the blocks.",
			"type": "boolean"
		},
		"blocks": {
			"description": "The block(s) to lock.",
			"type": "array",
			"items": {
				"type": "integer"
			}
		}
	},
	"oneOf": [
		{"required": ["all"]},
		{"required": ["blocks"]}
	],
	"required": [
		"command"
	]
}
