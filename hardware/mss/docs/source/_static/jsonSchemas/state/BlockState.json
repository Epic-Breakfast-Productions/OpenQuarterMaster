{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://github.com/Epic-Breakfast-Productions/OpenQuarterMaster/blob/main/hardware/mss/docs/source/_static/jsonSchemas/state/BlockState.json",
	"title": "Storage Block State Information.",
	"description": "The general info about a MSS Module Storage Block",
	"type": "object",
	"properties": {
		"blockNum": {
			"description": "The identifying number of this block in the set of blocks managed by the module. Not guaranteed ordering or corresponding to this object's place in the holding array.",
			"type": "integer",
			"minimum": 1
		},
		"lightSettings": {
			"title": "Block Light Settings",
			"$ref": "https://github.com/Epic-Breakfast-Productions/OpenQuarterMaster/blob/main/hardware/mss/docs/source/_static/jsonSchemas/state/BlockLightSetting.json"
		},
		"weightState": {
			"title": "Block Weight State",
			"$ref": "https://github.com/Epic-Breakfast-Productions/OpenQuarterMaster/blob/main/hardware/mss/docs/source/_static/jsonSchemas/state/BlockWeightState.json"
		},
		"locked": {
			"description": "If this block is locked.",
			"type": "boolean"
		}
	},
	"required": [
		"blockNum"
	]
}
