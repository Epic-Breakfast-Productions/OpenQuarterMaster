{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://github.com/Epic-Breakfast-Productions/OpenQuarterMaster/blob/main/hardware/mss/jsonSchemas/InventoryEventReport.json",
	"title": "Inventory Event Report",
	"description": "A report of changes to the stored inventory of this module.",
	"type": "object",
	"properties": {
		"weightStateChanges": {
			"description": "A set of block weight state changes to report on.",
			"type": "array",
			"items": {
				"$ref": "https://github.com/Epic-Breakfast-Productions/OpenQuarterMaster/blob/main/hardware/mss/jsonSchemas/BlockWeightReport.json"
			}
		},
		"uniqueItemChanges": {
			"description": "A set of unique items that were added or removed from the inventory.",
			"type": "array",
			"items": {
				"$ref": "https://github.com/Epic-Breakfast-Productions/OpenQuarterMaster/blob/main/hardware/mss/jsonSchemas/UniqueItemReport.json"
			}
		},
		"amountItemChanges": {
			"description": "A set of amount items that were added or removed from the inventory.",
			"type": "array",
			"items": {
				"$ref": "https://github.com/Epic-Breakfast-Productions/OpenQuarterMaster/blob/main/hardware/mss/jsonSchemas/AmountItemReport.json"
			}
		}
	},
	"anyOf": [
		{"required": ["weightStateChanges"]},
		{"required": ["uniqueItemChanges"]},
		{"required": ["amountItemChanges"]}
	],
	"required": [
		"weightValue",
		"weightUnit"
	]
}
