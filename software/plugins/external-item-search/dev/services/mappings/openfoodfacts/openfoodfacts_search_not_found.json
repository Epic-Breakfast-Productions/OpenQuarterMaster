{
  "request": {
    "urlPathPattern": "/openfoodfacts/search",
    "method": "GET",
    "queryParameters": {
      "q": {
        "not": {
          "equalTo": "beshbarmak"
        }
      },
      "page_size": {
        "matches": ".*"
      }
    }
  },
  "response": {
    "transformers": ["response-template"],
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "delayDistribution": {
      "type": "lognormal",
      "median": 5000,
      "sigma": 0.4
    },
    "jsonBody": {
      "count": 0,
      "page": 1,
      "page_count": 0,
      "page_size": "{{request.query.page_size}}",
      "hits": [],
      "skip": 0
    }
  }
}
