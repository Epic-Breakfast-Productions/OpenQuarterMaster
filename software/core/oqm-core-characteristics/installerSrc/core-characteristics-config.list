# Default config for oqm core characteristics server.

CHARACTERISTICS_UIS_ICON_DIR=/data/oqm/media
CHARACTERISTICS_RUNBY_IMG_DIR=/data/runBy

# Basic details
CHARACTERISTICS_VAL_TITLE={core.characteristics.characteristics.title}
CHARACTERISTICS_VAL_MOTD={core.characteristics.characteristics.motd}

# Run By details
CHARACTERISTICS_VAL_RUNBY_NAME={core.characteristics.characteristics.runBy.name}
CHARACTERISTICS_VAL_RUNBY_EMAIL={core.characteristics.characteristics.runBy.email}
CHARACTERISTICS_VAL_RUNBY_PHONE={core.characteristics.characteristics.runBy.phone}
CHARACTERISTICS_VAL_RUNBY_WEBSITE={core.characteristics.characteristics.runBy.website}
CHARACTERISTICS_VAL_RUNBY_LOGOIMG={core.characteristics.characteristics.runBy.logoImg}
CHARACTERISTICS_VAL_RUNBY_BANNERIMG={core.characteristics.characteristics.runBy.bannerImg}

# Banner details
CHARACTERISTICS_VAL_BANNER_TEXT={core.characteristics.characteristics.banner.text}
CHARACTERISTICS_VAL_BANNER_TEXTCOLOR={core.characteristics.characteristics.banner.textColor}
CHARACTERISTICS_VAL_BANNER_BACKGROUNDCOLOR={core.characteristics.characteristics.banner.backgroundColor}

# Homepage
UIS_HOME_URL={infra.homepage.externalBaseUri}
